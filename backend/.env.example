# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS (comma separated, optional)
CORS_ORIGIN=http://localhost:3000

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-super:free,deepseek/deepseek-v4-flash:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,google/gemma-4-31b:free
# Optional weights (higher = tried earlier among fallbacks)
OPENROUTER_MODEL_WEIGHTS=openai/gpt-oss-120b:free=100,nvidia/nemotron-3-super:free=95,deepseek/deepseek-v4-flash:free=90,qwen/qwen3-next-80b-a3b-instruct:free=85,meta-llama/llama-3.3-70b-instruct:free=80,google/gemma-4-31b:free=75
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=DevPath Assistant

# Firebase Admin (path relative to `backend/`; this repo stores it at `../service-account-key.json`)
FIREBASE_SERVICE_ACCOUNT_PATH=../service-account-key.json

# Rate limiting
ASSISTANT_RATE_LIMIT_PER_MINUTE=30
